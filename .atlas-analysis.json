  "keyFeatures": [
    "Terminal-based coding agent with guided and autonomous execution modes (Kata CLI)",
    "Headless orchestrator that polls Linear/GitHub and dispatches parallel agent sessions (Kata Symphony)",
    "Desktop app for multi-session AI agent management with MCP integrations (Kata Desktop)",
    "Spec-driven development harness for Claude Code, OpenCode, Gemini CLI, and Codex (Kata Orchestrator)",
    "Structural, semantic, and memory-based codebase indexing with tree-sitter and SQLite (Kata Context)",
    "Linear-backed project state: milestones, slices, tasks stored as Linear entities",
    "PR lifecycle management: create, review, address feedback, and merge via GitHub CLI",
    "Docker and SSH remote worker pools for distributed agent sessions (Symphony)",
    "Real-time event streaming and HTTP dashboard for observability (Symphony)",
    "MCP (Model Context Protocol) support for connecting external services"
  ],
  "publicApiSurface": [
    "npx @kata-sh/cli — Kata CLI",
    "npx @kata-sh/orc@latest — Kata Orchestrator installer",
    "npx @kata/context — Kata Context indexer",
    "symphony WORKFLOW.md — Kata Symphony binary",
    "/kata — CLI contextual wizard command",
    "/kata auto — autonomous execution mode",
    "/kata step — single-step execution mode",
    "/kata plan — enriched planning mode",
    "/kata pr — PR lifecycle management",
    "/symphony status|watch|console|config — Symphony operator commands",
    "GET /api/v1/state — Symphony orchestrator snapshot",
    "GET /api/v1/events — Symphony live WebSocket event stream",
    "POST /api/v1/escalations/:id/respond — respond to escalation",
    "/kata:new-project — Orchestrator: initialize project",
    "/kata:plan-phase N — Orchestrator: plan phase",
    "/kata:execute-phase N — Orchestrator: execute phase",
    "/kata:verify-work N — Orchestrator: verify phase",
    "/kata:quick — Orchestrator: ad-hoc quick mode"
  ]
